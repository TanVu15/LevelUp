# Firebase Configuration
# Tạo project tại: https://console.firebase.google.com
# Bật: Authentication (Google + Email/Password) + Firestore Database
# Copy config từ Project Settings > Your apps > Web app

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# App Check (chống spam Firestore bằng API key public) — tùy chọn, bỏ trống thì tắt.
# Tạo reCAPTCHA v3 site key: https://www.google.com/recaptcha/admin/create
# rồi đăng ký trong Firebase console → App Check. Xem .sdd/specs/feat-app-check/SPEC.md
VITE_RECAPTCHA_SITE_KEY=

# Firestore Security Rules (paste vào Firestore Rules tab):
# rules_version = '2';
# service cloud.firestore {
#   match /databases/{database}/documents {
#     match /users/{userId} {
#       allow read, write: if request.auth != null && request.auth.uid == userId;
#     }
#   }
# }

# Sau khi điền xong, copy file này thành .env.local:
# cp .env.example .env.local
