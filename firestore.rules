rules_version = '2';

// LevelUp — cloud sync chỉ là 1 document mỗi user tại users/{uid} (ADR-011).
// Nguyên tắc: chỉ chủ tài khoản (đã đăng nhập, uid khớp) mới đọc/ghi doc của mình.
// Mọi path khác bị từ chối mặc định.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Chỉ cho ghi doc của chính mình, và giới hạn kích thước doc (~1MB Firestore cap)
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.data.size() < 200;
    }

    // Chặn tất cả path còn lại.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
